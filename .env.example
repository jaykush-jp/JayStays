APP_NAME="MyRoom"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=Asia/Kolkata
APP_URL=http://localhost:8000

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=myroom_v2
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
CACHE_STORE=file
QUEUE_CONNECTION=sync

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback

# Razorpay — LEAVE EMPTY to use built-in DEMO/TEST mode (simulated payments).
# Get real test keys from https://dashboard.razorpay.com/app/keys
# Example: RAZORPAY_KEY_ID=rzp_test_AbC123...   RAZORPAY_KEY_SECRET=your_secret
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# PhonePe — optional, leave empty to skip
PHONEPE_MERCHANT_ID=
PHONEPE_SALT_KEY=
PHONEPE_SALT_INDEX=1
PHONEPE_ENV=UAT

# SMS — Fast2SMS
FAST2SMS_API_KEY=your-fast2sms-api-key

# Mail
MAIL_MAILER=smtp
MAIL_FROM_ADDRESS="noreply@myroom.in"
MAIL_FROM_NAME="MyRoom"

# SEO
SEO_SITE_NAME="MyRoom"
SEO_DEFAULT_IMAGE="https://myroom.in/images/og-default.jpg"

# Default commission %
DEFAULT_COMMISSION=10

# Hotel booking acceptance timeout (hours)
BOOKING_ACCEPT_TIMEOUT=2
